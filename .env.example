# Ethereum private key (Polygon) - with 0x prefix
PRIVATE_KEY=0x...

# Polymarket API credentials (auto-generated from private key)
# Run once, save these to reuse:
# CLOB_API_KEY=...
# CLOB_API_SECRET=...
# CLOB_API_PASSPHRASE=...

# Funder address (if using proxy/Safe wallet, otherwise leave empty)
FUNDER_ADDRESS=

# Signature type: 0=EOA, 1=POLY_PROXY, 2=GNOSIS_SAFE, 3=DEPOSIT_WALLET
SIGNATURE_TYPE=0

# Builder code (optional)
BUILDER_CODE=

# Trading params
MIN_EV=0.05
MAX_POSITION_SIZE=100
KELLY_FRACTION=0.25
